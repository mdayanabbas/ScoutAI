APP_NAME=ScoutAI API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+psycopg://scoutai:scoutai@localhost:5433/scoutai
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
HACKER_NEWS_API_BASE_URL=https://hacker-news.firebaseio.com/v0
HACKER_NEWS_REQUEST_TIMEOUT_SECONDS=10
HACKER_NEWS_MAX_CONCURRENCY=8
HACKER_NEWS_DEFAULT_LIMIT=50
HACKER_NEWS_MAX_LIMIT=200
HACKER_NEWS_DEFAULT_LOOKBACK_DAYS=30
COMPANY_ENRICHMENT_REQUEST_TIMEOUT_SECONDS=10
COMPANY_ENRICHMENT_MAX_REDIRECTS=3
COMPANY_ENRICHMENT_MAX_CANDIDATES_PER_RUN=50
COMPANY_ENRICHMENT_USER_AGENT=ScoutAI/0.1 company-domain-enrichment
YC_COMPANY_RESOLVER_ENABLED=true
YC_COMPANY_BASE_URL=https://www.ycombinator.com/companies
YC_COMPANY_REQUEST_TIMEOUT_SECONDS=10
YC_COMPANY_MAX_RETRIES=2
YC_COMPANY_USER_AGENT=ScoutAI/0.1 YC-company-resolver
YC_JOB_REQUEST_TIMEOUT_SECONDS=10
YC_JOB_MAX_REDIRECTS=3
YC_JOB_MAX_RESPONSE_BYTES=2000000
YC_JOB_USER_AGENT=ScoutAI/0.1 job-enrichment
YC_JOB_MAX_RETRIES=1
ASHBY_JOB_PUBLIC_API_BASE_URL=https://api.ashbyhq.com/posting-api/job-board
ASHBY_JOB_REQUEST_TIMEOUT_SECONDS=10
ASHBY_JOB_MAX_RETRIES=1
ASHBY_JOB_MAX_RESPONSE_BYTES=4000000
ASHBY_JOB_USER_AGENT=ScoutAI/0.1 job-enrichment
ASHBY_JOB_MAX_POSTINGS_PER_BOARD=200
ASHBY_JOB_MATCH_MIN_CONFIDENCE=0.90
ASHBY_JOB_MATCH_MIN_GAP=0.10
ASHBY_BOARD_EXPANSION_MAX_POSTINGS=200
ASHBY_BOARD_EXPANSION_MIN_MATCH_SCORE=0.75
ASHBY_BOARD_EXPANSION_MIN_SCORE_GAP=0.10
ASHBY_BOARD_EXPANSION_MAX_CREATE=25
ASHBY_BOARD_EXPANSION_ALLOW_BROAD_HIRING=true
JOB_ENRICHMENT_BATCH_DEFAULT_LIMIT=10
JOB_ENRICHMENT_BATCH_MAX_LIMIT=50
JOB_ENRICHMENT_BATCH_DELAY_MS=0
ASHBY_RESOLVER_ENABLED=true
ASHBY_POSTING_API_BASE_URL=https://api.ashbyhq.com/posting-api/job-board
ASHBY_REQUEST_TIMEOUT_SECONDS=10
ASHBY_MAX_RETRIES=2
ASHBY_MAX_RESPONSE_BYTES=2000000
ASHBY_USER_AGENT=ScoutAI/0.1 Ashby-public-job-resolver
ASHBY_INCLUDE_COMPENSATION=true
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_MAX_QUERIES_PER_CANDIDATE=2
WEB_SEARCH_RESULTS_PER_QUERY=5
WEB_SEARCH_REQUEST_TIMEOUT_SECONDS=10
WEB_SEARCH_MAX_RETRIES=1
WEB_SEARCH_MAX_RESPONSE_BYTES=1000000
TAVILY_API_KEY=
TAVILY_SEARCH_BASE_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=basic
TAVILY_USER_AGENT=ScoutAI/0.1 company-identity-search
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_USER_AGENT=ScoutAI/0.1 company-identity-search
DISCOVERY_JOB_INGESTION_MAX_CANDIDATES_PER_RUN=100
