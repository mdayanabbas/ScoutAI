APP_NAME=ScoutAI API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+psycopg://scoutai:scoutai@localhost:5433/scoutai
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
HACKER_NEWS_API_BASE_URL=https://hacker-news.firebaseio.com/v0
HACKER_NEWS_REQUEST_TIMEOUT_SECONDS=10
HACKER_NEWS_MAX_CONCURRENCY=8
HACKER_NEWS_DEFAULT_LIMIT=50
HACKER_NEWS_MAX_LIMIT=200
HACKER_NEWS_DEFAULT_LOOKBACK_DAYS=30
COMPANY_ENRICHMENT_REQUEST_TIMEOUT_SECONDS=10
COMPANY_ENRICHMENT_MAX_REDIRECTS=3
COMPANY_ENRICHMENT_MAX_CANDIDATES_PER_RUN=50
COMPANY_ENRICHMENT_USER_AGENT=ScoutAI/0.1 company-domain-enrichment
YC_COMPANY_RESOLVER_ENABLED=true
YC_COMPANY_BASE_URL=https://www.ycombinator.com/companies
YC_COMPANY_REQUEST_TIMEOUT_SECONDS=10
YC_COMPANY_MAX_RETRIES=2
YC_COMPANY_USER_AGENT=ScoutAI/0.1 YC-company-resolver
DISCOVERY_JOB_INGESTION_MAX_CANDIDATES_PER_RUN=100
